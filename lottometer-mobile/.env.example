# Override the API base URL for local development
# Leave commented out to use production (https://api.lottometer.com/api)
# EXPO_PUBLIC_API_URL=http://192.168.1.248:5000/api

# Optional: Sentry DSN for error tracking in production builds
# Leave commented out for local development to avoid noise
# EXPO_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...