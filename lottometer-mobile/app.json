{
  "expo": {
    "name": "LottoMeter",
    "slug": "lottometer-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-1.png",
      "resizeMode": "contain",
      "backgroundColor": "#F6FAFF"
    },
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/app-icon.png"
    },
    "android": {
      "package": "com.lottometer.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#F6FAFF"
      },
      "edgeToEdgeEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-splash-screen",
      "expo-secure-store",
      "expo-localization",
      "@react-native-community/datetimepicker",
      [
        "@sentry/react-native",
        {
          "organization": "lottometer",
          "project": "lottometer-mobile"
        }
      ],
      "expo-audio",
      "expo-sqlite"
    ],
    "extra": {
      "eas": {
        "projectId": "e100a58f-8393-4995-a06c-7903b8b3d05d"
      }
    },
    "owner": "almomani",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e100a58f-8393-4995-a06c-7903b8b3d05d"
    }
  }
}
