# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-string-in-production

# Database
# - Local dev (SQLite, no docker):
DATABASE_URL=sqlite:///lottometer.db
# - Docker (PostgreSQL via docker-compose):
# DATABASE_URL=postgresql://lottometer:lottometer_dev_pw@db:5432/lottometer
# - Production (your real PostgreSQL):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# JWT
JWT_SECRET_KEY=change-this-to-a-different-random-string
JWT_ACCESS_TOKEN_EXPIRES_HOURS=168

# Stripe (required when PAYMENTS_ENABLED=True)
# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PRICE_ID=price_xxx

# Email / SendGrid (required when EMAIL_ENABLED=True)
# SENDGRID_API_KEY=SG.xxx