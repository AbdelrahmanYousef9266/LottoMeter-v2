# Flask
FLASK_APP=run.py
FLASK_ENV=development
SECRET_KEY=change-this-to-a-random-string-in-production

# Database (dev = SQLite, prod = PostgreSQL)
DATABASE_URL=sqlite:///lottometer.db
# DATABASE_URL=postgresql://user:password@localhost:5432/lottometer

# JWT
JWT_SECRET_KEY=change-this-to-a-different-random-string
JWT_ACCESS_TOKEN_EXPIRES_HOURS=8